{
  "name": "@capyup/pi-exa",
  "version": "0.4.1",
  "description": "Exa web research for pi via five first-class tools + skill + local CLI. Uses the official exa-js SDK directly — no MCP server, no adapter. Tools: exa_search, exa_similar, exa_fetch, exa_answer, exa_research. Supports real-time livecrawl, subpage extraction, structured JSON output, and deep multi-step research.",
  "repository": {
    "type": "git",
    "url": "https://github.com/capyup/pi-exa"
  },
  "author": "capyup",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-skill",
    "exa",
    "web-search",
    "research"
  ],
  "files": [
    "extensions",
    "skills",
    "prompts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "exa-js": "^2.12.1"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  }
}
